---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
import ProjectItem from '../components/ProjectItem.astro';

const metaData = (await getEntry('data', 'meta'))!.data as any;
const projectsData = (await getEntry('data', 'projects'))!.data as any;
---

<Layout
  title={metaData.projects.title}
  description={metaData.projects.description}
  url={metaData.projects.url}
>
  <main class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <section>
      <header class="mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 text-white">Projects</h1>
        <p class="text-lg text-zinc-400">A collection of things I've built and worked on.</p>
      </header>

      <div class="space-y-20">
        {projectsData.projects.map((project: any) => <ProjectItem {...project} />)}
      </div>
      <br />
    </section>
  </main>
</Layout>
