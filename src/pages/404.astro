---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
const metaData = (await getEntry('data', 'meta'))!.data as any;
---

<Layout
  title={metaData.notfound.title}
  description={metaData.notfound.description}
  url={metaData.notfound.url}
>
  <main
    class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full flex flex-col justify-center items-center text-center"
  >
    <section>
      <h1 class="text-6xl font-bold text-white mb-4 tracking-tight">404</h1>
      <h2 class="text-2xl text-zinc-400 font-medium mb-8">Page Not Found</h2>
      <p class="text-[1.05rem] md:text-lg text-zinc-300 leading-relaxed max-w-md mx-auto mb-10">
        The page you are looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-black bg-white hover:bg-zinc-200 transition-colors duration-200"
      >
        Return Home
      </a>
    </section>
  </main>
</Layout>
