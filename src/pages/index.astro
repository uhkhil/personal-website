---
import Layout from '../layouts/Layout.astro';
import profileData from '../../data/profile.json';
import metaData from '../../data/meta.json';
---

<Layout title={metaData.home.title} description={metaData.home.description} url={metaData.home.url}>
  <main
    class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full flex flex-col justify-center"
  >
    <section class="animate-fade-in-up">
      <!-- Mobile Layout: Centered Image & Text -->
      <div class="md:hidden flex flex-col items-center text-center mb-8 pt-4">
        <div
          class="w-40 h-40 rounded-full overflow-hidden bg-zinc-800 flex items-center justify-center relative shadow-lg mb-6"
        >
          <img
            src="/headshot.webp"
            alt={profileData.name}
            class="w-full h-full object-cover relative z-10"
          />
        </div>
        <div>
          <h1 class="text-4xl font-bold text-white mb-2 tracking-tight">{profileData.name}</h1>
          <h2 class="text-xl text-zinc-400 font-medium">{profileData.role}</h2>
        </div>
      </div>

      <!-- Desktop Layout: Floating Image -->
      <div
        class="hidden md:block float-right ml-10 mb-6 w-56 h-56 rounded-full overflow-hidden bg-zinc-800 flex items-center justify-center relative shadow-lg"
      >
        <img
          src="/headshot.webp"
          alt={profileData.name}
          class="w-full h-full object-cover relative z-10"
        />
      </div>

      <div class="hidden md:block mb-8 pt-2">
        <h1 class="text-5xl font-bold text-white mb-2 tracking-tight">{profileData.name}</h1>
        <h2 class="text-2xl text-zinc-400 font-medium">{profileData.role}</h2>
      </div>

      <div
        class="text-[1.05rem] md:text-lg text-zinc-300 leading-relaxed md:leading-[1.8] space-y-8 pt-4 md:pt-0"
      >
        {profileData.paragraphs.map((p) => <p>{p}</p>)}
      </div>

      <div class="mt-12 flex gap-4 flex-wrap clear-both pb-8">
        <a
          href={`mailto:${profileData.contact.email}`}
          class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-black bg-white hover:bg-zinc-200 transition-colors duration-200"
        >
          {profileData.contact.buttonText}
        </a>
      </div>
    </section>
  </main>
</Layout>
