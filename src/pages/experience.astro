---
import Layout from '../layouts/Layout.astro';
import { getEntry } from 'astro:content';
const metaData = (await getEntry('data', 'meta'))!.data as any;
const experienceData = (await getEntry('data', 'experience'))!.data as any;
import ExperienceItem from '../components/ExperienceItem.astro';
---

<Layout
  title={metaData.experience.title}
  description={metaData.experience.description}
  url={metaData.experience.url}
>
  <main class="flex-grow max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 w-full">
    <section class="animate-fade-in-up">
      <header class="mb-12">
        <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4 text-white">
          Work Experience
        </h1>
        <p class="text-lg text-zinc-400">A timeline of my professional journey.</p>
      </header>

      <div class="space-y-16">
        {experienceData.experiences.map((exp: any) => <ExperienceItem {...exp} />)}
      </div>
      <br />
    </section>
  </main>
</Layout>
