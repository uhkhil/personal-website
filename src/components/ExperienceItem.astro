---
export interface Props {
  period: string;
  role: string;
  company: string;
  location: string;
  description: string;
  highlights: string[];
}

const { period, role, company, location, description, highlights } = Astro.props;
---

<article class="relative pl-12 sm:pl-0">
  <div class="flex flex-col sm:flex-row sm:gap-16">
    <div
      class="sm:w-1/4 pb-2 sm:pb-0 text-zinc-300 text-sm sm:text-right pt-1 font-medium tracking-wide uppercase"
    >
      {period}
    </div>
    <div class="sm:w-3/4 relative pb-px">
      <div
        class="absolute -left-12 sm:-left-8 top-2 w-3 h-3 bg-zinc-600 rounded-full border-2 border-black z-10"
      >
      </div>
      <!-- Line connecting items -->
      <div
        class="absolute -left-[43px] sm:-left-[27px] top-7 bottom-[-6rem] md:bottom-[-4rem] w-0.5 bg-zinc-800"
      >
      </div>
      <h2 class="text-xl font-bold text-white">{role}</h2>
      <div class="text-zinc-300 font-medium mb-4">{company} &middot; {location}</div>
      <p class="text-zinc-400 leading-relaxed mb-4">{description}</p>

      <h3 class="text-sm font-semibold text-zinc-300 tracking-wider mb-2 mt-6">Highlights</h3>
      <ul class="list-disc list-inside text-zinc-400 space-y-1 text-sm">
        {highlights.map((highlight) => <li>{highlight}</li>)}
      </ul>
    </div>
  </div>
</article>
