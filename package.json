{
  "name": "personal-website",
  "version": "1.0.0",
  "private": true,
  "description": "Personal website and developer portfolio showcasing my work, experience, and projects.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "deploy": "npm run build && wrangler deploy",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhkhil/personal-website.git"
  },
  "keywords": [
    "portfolio",
    "website",
    "developer",
    "vite",
    "handlebars",
    "tailwindcss"
  ],
  "author": "Akhil Kumar",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/uhkhil/personal-website/issues"
  },
  "homepage": "https://github.com/uhkhil/personal-website#readme",
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-handlebars": "^2.0.0",
    "wrangler": "^4.71.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,css,json,md}": "prettier --write"
  }
}
